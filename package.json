{
  "name": "node-express-ts-feature-based-boilerplate",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "pnpm run install-core-dependencies && pnpm run install-dev-dependencies",
    "install-core-dependencies": "pnpm add express cors helmet morgan dotenv typeorm reflect-metadata pg class-validator class-transformer bcrypt jsonwebtoken cli-table3 chalk winston ioredis mysql2 pluralize",
    "install-dev-dependencies": "pnpm add -D typescript ts-node ts-node-dev @types/node @types/express @types/cors @types/morgan @types/bcrypt @types/jsonwebtoken @types/pg @types/pluralize tsx tsc-alias tsconfig-paths nodemon",
    "generate:module": "tsx src/scripts/generate-module.ts"
  },
  "keywords": [
    "node",
    "express",
    "typescript",
    "postgresql",
    "boilerplate",
    "jwt",
    "typeorm",
    "feature-based"
  ],
  "author": "Danilo Alingasa",
  "license": "ISC",
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cli-table3": "^0.6.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "pluralize": "^8.0.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/pluralize": "^0.0.33",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
